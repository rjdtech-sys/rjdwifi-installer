NODE_ENV=production
PORT=80

# RJD Cloud licensing and setup gate
RJD_USE_CLOUD_LICENSE_API=true
RJD_LICENSE_API_URL=https://api.rjdtech.shop
RJD_EDGE_API_TOKEN=replace-with-token-issued-by-rjd-cloud
RJD_LICENSE_OFFLINE_GRACE_HOURS=72
RJD_ALLOW_LOCAL_LICENSE_FALLBACK=false
RJD_SKIP_NETWORK_RESTORE=true

# Factory setup WiFi access point
# Orange Pi One requires a USB WiFi adapter that supports AP mode.
RJD_SETUP_AP_SSID=RJD-Setup
RJD_SETUP_AP_PASSWORD=
RJD_SETUP_AP_IP=10.0.0.1
RJD_SETUP_AP_DHCP_RANGE=10.0.0.50,10.0.0.250,12h
RJD_SETUP_WIFI_IFACE=

# Optional prefill for dealer-assisted activation
RJD_LICENSE_EMAIL=
RJD_LICENSE_PASSWORD=
RJD_DEVICE_NAME=
RJD_BOARD_TYPE=auto

# Optional cloud sync for sales/fleet data
SUPABASE_URL=
SUPABASE_ANON_KEY=
MACHINE_ID=
VENDOR_ID=
